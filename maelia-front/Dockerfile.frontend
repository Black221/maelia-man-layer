# frontend/Dockerfile — React/Vite, build multi-stage servi par nginx

# --- Étape 1 : build ---
FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
# L'URL de l'API peut être injectée au build (Vite) ; par défaut, nginx proxifie /api et /ws.
RUN npm run build

# --- Étape 2 : runtime (nginx) ---
FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
